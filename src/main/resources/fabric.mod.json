{
	"schemaVersion": 1,
	"id": "multicmd",
	"version": "${version}",
	"name": "MultiCmd",
	"description": "Производительный клиентский инструмент для пакетной обработки команд и макросов.",
	"authors": ["TAOSHOI"],
	"contact": {
		"homepage": "https://github.com/TAOSHOI/MultiCmd",
		"sources": "https://github.com/TAOSHOI/MultiCmd",
		"issues": "https://github.com/TAOSHOI/MultiCmd/issues"
	},
	"license": "MIT",
	"icon": "assets/multicmd/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.multicmd.start.client.MultiCmdClient"
		],
		"modmenu":[
			"com.multicmd.start.client.integration.ModMenuIntegration"
		]
	},
	"mixins":[
		"multicmd.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.5",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}